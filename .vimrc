" General options
set encoding=utf-8
set ruler
set nu

" Searching
set hlsearch
set ignorecase
set incsearch

" Pathogen
execute pathogen#infect()

" Lightline
set laststatus=2

"" Gvim
set guifont=Droid_Sans_Mono:h10:cANSI
set backspace=2

" Colors
set t_Co=256
syntax enable
colorscheme PaperColor
set background=dark
